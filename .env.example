# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AQ.Ab8RN6JtE2gbWQjEib9-vAjuUACJ1scUrTrRVOtjRf9AzzszyA"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.

# N8N_WEBHOOK_URL: URL for the n8n webhook that bridges CRM campaigns to ad networks.
# This is the endpoint the Express backend calls when a campaign is approved and pushed live.
# Use the production webhook for live execution, or the webhook-test URL during n8n workflow development.
N8N_WEBHOOK_URL="https://akigh90.app.n8n.cloud/webhook/crm-campaign-trigger"
NEXT_PUBLIC_N8N_WEBHOOK_URL="https://akigh90.app.n8n.cloud/webhook/crm-campaign-trigger"

# META_AD_ACCOUNT_ID: Default Facebook Ads account ID to use when pushing campaigns.
_ADMETA_ACCOUNT_ID="act_123456789"

# GOOGLE_ADS_CUSTOMER_ID: Default Google Ads customer ID to use when pushing campaigns.
GOOGLE_ADS_CUSTOMER_ID="123-456-7890"